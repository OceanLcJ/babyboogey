      "faq": {
        "id": "faq",
        "eyebrow": "Good Questions",
        "helper": {
          "label": "Still unsure?",
          "text": "Credit packs start as small as a single render, so you can try one video before buying more."
        },
        "title": "Frequently Asked Questions",
        "description": "Everything you need to know about our AI baby dance generator.",
        "items": [
          {
            "question": "How much does the AI baby dance generator cost?",
            "answer": "BabyBoogey runs on a credit system — videos are billed per second (15 credits/s for 720p, 25 credits/s for 1080p) and AI baby photos cost 12 credits for 2K or 25 for 4K. Credit packs start small, so you can try a single render before committing. Paid plans unlock premium templates and larger credit bundles."
          },
          {
            "question": "How does the face animator online work?",
            "answer": "Upload any photo and our AI will animate baby photo faces with natural-looking movements. The face animator online preserves facial features while adding fun dance moves and expressions."
          },
          {
            "question": "How long does it take to turn photo into dancing baby?",
            "answer": "Most videos are ready in under 30 seconds. Our AI baby dance generator is optimized for speed so you can share your baby dance video instantly on social media."
          },
          {
            "question": "Do I need professional photos to animate baby photos?",
            "answer": "Not at all! Any clear snapshot works with our baby dance video maker. Even casual selfies become amazing baby photo masterpieces with our AI technology."
          },
          {
            "question": "Is it safe to use my baby's photos?",
            "answer": "Absolutely. Your photos are processed securely and never shared with third parties. All uploaded images are stored privately and you can delete them anytime from your account."
          },
          {
            "question": "What photo formats and sizes are supported?",
            "answer": "We support JPG, PNG, and WebP formats. For best results, use a clear front-facing photo with good lighting. The minimum recommended size is 512x512 pixels."
          },
          {
            "question": "Can I use BabyBoogey for adults or pets?",
            "answer": "Yes! While BabyBoogey is designed for baby photos, our AI face animator works great with any clear face photo — adults, kids, and even pets with visible faces."
          },
          {
            "question": "How do I share my baby dance video on TikTok or Instagram?",
            "answer": "After generating your video, click the download button to save it to your device. Then simply upload it to TikTok, Instagram Reels, or any social media platform directly from your gallery."
          }
        ]
      },
